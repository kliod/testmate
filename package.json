{
  "name": "testmate",
  "version": "1.0.0",
  "description": "Unified AI-native Web Testing Orchestrator",
  "type": "module",
  "main": ".testmate/testmate.mjs",
  "bin": {
    "testmate": ".testmate/testmate.mjs"
  },
  "scripts": {
    "test": "node --test",
    "test:unit": "node --test",
    "testmate:targeted": "node .testmate/testmate.mjs tier-1-targeted",
    "testmate:integrity": "node .testmate/testmate.mjs tier-2-impact",
    "testmate:stability": "node .testmate/testmate.mjs tier-3-full",
    "testmate:metrics": "node .testmate/testmate.mjs --show-metrics",
    "testmate:benchmark-fixtures": "node .testmate/testmate.mjs --benchmark-fixtures",
    "testmate:replay-fixtures": "node .testmate/testmate-fixtures.mjs"
  },
  "keywords": [
    "testing",
    "ai",
    "orchestrator",
    "quality-gate",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
