{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Quality Gate Output",
  "type": "object",
  "required": [
    "status",
    "mode",
    "analysisScope",
    "riskLevel",
    "changeType",
    "decisionFactors",
    "findings",
    "affectedAreas",
    "subagentsRun",
    "skippedAgents",
    "blockers",
    "warnings",
    "summary"
  ],
  "properties": {
    "status": {
      "enum": [
        "PASS",
        "WARNING",
        "BLOCK",
        "NEED_INFO"
      ]
    },
    "mode": {
      "enum": [
        "pre_commit",
        "pre_mr",
        "pre_merge",
        "pre_release"
      ]
    },
    "analysisScope": {
      "enum": [
        "DIFF",
        "AFFECTED",
        "FULL"
      ]
    },
    "riskLevel": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "changeType": {
      "type": "string",
      "minLength": 1
    },
    "decisionFactors": {
      "type": "object",
      "required": [
        "impact",
        "likelihood",
        "confidence",
        "coverageGap",
        "businessCriticality"
      ],
      "properties": {
        "impact": {
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "CRITICAL"
          ]
        },
        "likelihood": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "coverageGap": {
          "enum": [
            "NONE",
            "MINOR",
            "MATERIAL",
            "BLOCKING"
          ]
        },
        "businessCriticality": {
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "CRITICAL"
          ]
        }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "agent",
          "evidence",
          "confidence",
          "recommendedAction"
        ],
        "properties": {
          "severity": {
            "enum": [
              "BLOCK",
              "WARNING"
            ]
          },
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "recommendedAction": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "affectedAreas": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "subagentsRun": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "skippedAgents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "agent",
          "reason"
        ],
        "properties": {
          "agent": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "requiredCoverage": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "existingCoverage": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "missingCoverage": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "questionsForUser": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "interaction": {
      "type": "object",
      "properties": {
        "state": {
          "enum": [
            "complete",
            "need_info",
            "resumable"
          ]
        },
        "blockedDecision": {
          "type": "string"
        },
        "resumeToken": {
          "type": "string"
        },
        "answersExpected": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "question",
              "unblocks"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "question": {
                "type": "string",
                "minLength": 1
              },
              "unblocks": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "receivedAnswers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "answer"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "question": {
                "type": "string",
                "minLength": 1
              },
              "unblocks": {
                "type": "string",
                "minLength": 1
              },
              "answer": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "recommendedTests": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "commandsToRun": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "manualQA": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "residualRisks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "runtimeMs": {
          "type": "number",
          "minimum": 0
        },
        "selectedAgents": {
          "type": "number",
          "minimum": 0
        },
        "changedFiles": {
          "type": "number",
          "minimum": 0
        },
        "model": {
          "type": "string"
        },
        "promptChars": {
          "type": "number",
          "minimum": 0
        },
        "responseChars": {
          "type": "number",
          "minimum": 0
        },
        "retryCount": {
          "type": "number",
          "minimum": 0
        },
        "diffSliced": {
          "type": "boolean"
        },
        "diffOriginalChars": {
          "type": "number",
          "minimum": 0
        },
        "diffSelectedChars": {
          "type": "number",
          "minimum": 0
        },
        "diffOmittedFiles": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "auditLogPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\.md$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
