{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Quality Gate Output",
  "type": "object",
  "required": [
    "status",
    "mode",
    "analysisScope",
    "riskLevel",
    "changeType",
    "affectedAreas",
    "subagentsRun",
    "policyRulesTriggered",
    "evidence",
    "requiredCoverage",
    "existingCoverage",
    "missingCoverage",
    "blockers",
    "warnings",
    "recommendedTests",
    "commandsToRun",
    "manualQA",
    "waivers",
    "overrides",
    "residualRisks",
    "questionsForUser",
    "auditLogPath",
    "summary"
  ],
  "additionalProperties": true,
  "properties": {
    "status": {
      "enum": [
        "PASS",
        "WARNING",
        "BLOCK",
        "NEED_INFO"
      ]
    },
    "mode": {
      "enum": [
        "pre_commit",
        "pre_mr",
        "pre_merge",
        "pre_release"
      ]
    },
    "analysisScope": {
      "enum": [
        "DIFF",
        "AFFECTED",
        "FULL"
      ]
    },
    "riskLevel": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "changeType": {
      "type": "string"
    },
    "affectedAreas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "subagentsRun": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policyRulesTriggered": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "requiredCoverage": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "existingCoverage": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missingCoverage": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendedTests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commandsToRun": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manualQA": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "waivers": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "overrides": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "residualRisks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "questionsForUser": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "auditLogPath": {
      "type": "string",
      "pattern": "^logs\\/(pre_commit|pre_mr|pre_merge|pre_release)_[^\\/]+\\.md$"
    },
    "summary": {
      "type": "string"
    }
  }
}
